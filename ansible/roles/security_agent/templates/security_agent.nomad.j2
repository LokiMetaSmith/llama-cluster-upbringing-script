job "security-agent" {
  datacenters = ["dc1"]
  type        = "service"

  group "security-agent" {
    count = 1

    # Pin to the controller node where the image was built
    constraint {
      attribute = "${attr.unique.hostname}"
      value     = "{{ inventory_hostname }}"
    }

    network {
      port "tcp" {
        to = 9000
      }
    }

    service {
      name = "security-agent"
      port = "tcp"

      check {
        type     = "tcp"
        interval = "10s"
        timeout  = "2s"
      }
    }

    task "security-agent" {
      driver = "docker"

      config {
        image = "local/security-agent:latest"
        ports = ["tcp"]
      }

      env {
        MQTT_BROKER     = "{{ cluster_ip | default('127.0.0.1') }}"
        MQTT_PORT       = "1883"
        TCP_LISTEN_PORT = "9000"
      }

      resources {
        cpu    = 200
        memory = 256
      }
    }
  }
}
