[Unit]
Description=Nomad Agent
Documentation=https://www.nomadproject.io/docs/
Wants=consul.service network-online.target
After=consul.service network-online.target

[Service]
User=root
Group=root
ExecReload=/bin/kill -HUP $MAINPID
ExecStart=/usr/local/bin/start_nomad.sh
StandardOutput=append:/var/log/nomad.log
StandardError=append:/var/log/nomad.log
KillMode=mixed
KillSignal=SIGINT
TimeoutStopSec=30s
LimitNOFILE=65536
LimitNPROC=infinity
Restart=always
RestartSec=5s
StartLimitBurst=5
StartLimitInterval=10s
TasksMax=infinity

[Install]
WantedBy=multi-user.target
