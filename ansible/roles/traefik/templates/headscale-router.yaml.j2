http:
  routers:
    headscale:
      rule: "Host(`headscale.{{ cluster_domain | default('local.mesh') }}`)"
      service: headscale
      entryPoints:
        - websecure
      tls:
        {% if traefik_acme_enabled | bool %}
        certResolver: dnsresolver
        {% endif %}

  services:
    headscale:
      loadBalancer:
        servers:
          - url: "http://{{ hostvars[groups['controller_nodes'][0]]['ansible_host'] | default(hostvars[groups['controller_nodes'][0]]['ansible_facts']['default_ipv4']['address'] | default('127.0.0.1')) }}:8085"
