job "tool-server" {
  datacenters = {{ nomad_datacenters | default(['dc1']) | to_json }}
  type        = "service"

  group "tool-server-group" {
    count = 1

    network {
      port "http" {
        static = "{{ tool_server_port | default(8006) }}"
      }
    }

    {% set image_cid = tool_server_ipfs_cid %}

    {% set image_tar_name = 'tool_server' %}

    {% include 'load_image_task.nomad.j2' %}

    volume "cluster-infra" {
      type      = "host"
      source    = "cluster-infra"
      read_only = true
    }

    volume "mcp-config" {
      type      = "host"
      source    = "mcp-config"
      read_only = false
    }

    task "tool-server-task" {
      driver = "docker"

      config {
        image = "tool-server:local"
        force_pull = false
        ports = ["http"]

        # Volatile RAM disk for workspace
        mounts = [
          {
            type   = "tmpfs"
            target = "/opt/cluster-infra"
            tmpfs_options = {
              size = 1073741824 # 1GB
            }
          }
        ]

        volumes = [
          # Docker socket for CodeRunnerTool
          "/var/run/docker.sock:/var/run/docker.sock"
        ]

        command = "uvicorn"
        args = ["app:app", "--host", "0.0.0.0", "--port", "${NOMAD_PORT_http}"]
      }

      volume_mount {
        volume      = "cluster-infra"
        destination = "/mnt/host_repo"
        read_only   = true
      }

      volume_mount {
        volume      = "mcp-config"
        destination = "/opt/mcp"
        read_only   = false
      }

      env {
        TOOL_SERVER_API_KEY = "{{ openai_api_key }}"
        HA_URL              = "{{ env_ha_url | default('') }}"
        HA_TOKEN            = "{{ env_ha_token | default('') }}"
        GITHUB_TOKEN        = "{{ github_token | default('') }}"
        GIT_USERNAME        = "{{ git_username | default('Pipecat Agent') }}"
        GIT_EMAIL           = "{{ git_email | default('agent@pipecat.ai') }}"
      }

      resources {
        cpu    = 1000
        memory = 2048
      }
      
      service {
        name = "tool-server-api"
        port = "http"
        tags = ["tool-server-api", "http"]

        check {
          type     = "http"
          path     = "/health"
          interval = "15s"
          timeout  = "5s"
        }
      }
    }
  }
}
