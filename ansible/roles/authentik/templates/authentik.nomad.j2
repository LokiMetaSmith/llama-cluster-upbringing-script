job "authentik" {
  datacenters = {{ nomad_datacenters | default(['dc1']) | to_json }}
  type        = "service"

update {
  max_parallel      = 1
  min_healthy_time  = "60s"
  healthy_deadline  = "15m"
  progress_deadline = "30m"
  canary            = 1
  auto_revert       = false
}

  group "authentik" {
    network {
      mode = "{{ authentik_network_mode | default('bridge') }}"
      dns {
        servers = ["{{ cluster_ip | default('172.17.0.1') }}", "8.8.8.8"]
      }
      port "http" {
        static = {{ authentik_http_port | default(9000) }}
        to     = 9000
      }
      port "https" {
        static = {{ authentik_https_port | default(9443) }}
        to     = 9443
      }
      port "redis" {
        static = {{ authentik_redis_port | default(16379) }}
        to = 6379
      }
      port "postgres" {
        static = {{ authentik_postgres_port | default(15432) }}
        to = 5432
      }
    }

    task "redis" {
      driver = "docker"

      config {
        image = "redis:7.2-alpine"
        ports = ["redis"]
      }

      service {
        name = "redis"
        port = "redis"
        check {
          name     = "alive"
          type     = "tcp"
          interval = "10s"
          timeout  = "2s"
        }
      }

      resources {
        cpu    = 100
        memory = 128
      }

      restart {
        interval = "30s"
        delay    = "15s"
        mode     = "delay"
      }
    }

    volume "authentik-postgres" {
      type      = "host"
      read_only = false
      source    = "authentik-postgres"
    }

    volume "authentik-media" {
      type      = "host"
      read_only = false
      source    = "authentik-media"
    }

    volume "authentik-templates" {
      type      = "host"
      read_only = false
      source    = "authentik-templates"
    }

    volume "authentik-certs" {
      type      = "host"
      read_only = false
      source    = "authentik-certs"
    }

    task "postgresql" {
      driver = "docker"

      volume_mount {
        volume      = "authentik-postgres"
        destination = "/var/lib/postgresql/data"
      }

      config {
        image = "postgres:15-alpine"
        ports = ["postgres"]
      }

      service {
        name = "postgres"
        port = "postgres"
        check {
          name     = "alive"
          type     = "tcp"
          interval = "10s"
          timeout  = "2s"
        }
      }

      template {
        data = <<EOH
POSTGRES_PASSWORD="{{ '{{' }} key "authentik/db-password" {{ '}}' }}"
EOH
        destination = "secrets/postgres.env"
        env         = true
      }

      env {
        POSTGRES_USER     = "{{ authentik_db_user | default('authentik') }}"
        POSTGRES_DB       = "{{ authentik_db_name | default('authentik') }}"
      }

      resources {
        cpu    = 200
        memory = 256
      }

      restart {
        interval = "30s"
        delay    = "15s"
        mode     = "delay"
      }
    }

    task "server" {
      driver = "docker"

      volume_mount {
        volume      = "authentik-media"
        destination = "/media"
      }

      volume_mount {
        volume      = "authentik-templates"
        destination = "/templates"
      }

      config {
        image        = "ghcr.io/goauthentik/server:2024.2.2"
        args         = ["server"]
        ports        = ["http", "https"]
      }

      template {
        data = <<EOH
CONSUL_HTTP_TOKEN="{{ consul_bootstrap_token | default('') }}"
AUTHENTIK_SECRET_KEY="{{ '{{' }} key "authentik/secret-key" {{ '}}' }}"
AUTHENTIK_REDIS__HOST="{{ '{{' }} env "attr.unique.network.ip-address" {{ '}}' }}"
AUTHENTIK_REDIS__PORT="{{ authentik_redis_port | default(16379) }}"
AUTHENTIK_POSTGRESQL__HOST="{{ '{{' }} env "attr.unique.network.ip-address" {{ '}}' }}"
AUTHENTIK_POSTGRESQL__PORT="{{ authentik_postgres_port | default(15432) }}"
AUTHENTIK_POSTGRESQL__PASSWORD="{{ '{{' }} key "authentik/db-password" {{ '}}' }}"
EOH
        destination = "secrets/authentik.env"
        env         = true
      }

      env {
        AUTHENTIK_POSTGRESQL__USER = "{{ authentik_db_user | default('authentik') }}"
        AUTHENTIK_POSTGRESQL__NAME = "{{ authentik_db_name | default('authentik') }}"
        AUTHENTIK_ERROR_REPORTING__ENABLED = "true"
        AUTHENTIK_WEB__WORKERS = "{{ authentik_web_workers | default(2) }}"
        GUNICORN_CMD_ARGS = "{{ authentik_gunicorn_cmd_args | default('--max-requests 250 --max-requests-jitter 50') }}"
      }

      service {
        name = "authentik"
        port = "http"
        tags = [
          "traefik.enable=true",
          "traefik.http.routers.authentik.rule=Host(`authentik.{{ cluster_domain | default('local.mesh') }}`)",
          "traefik.http.routers.authentik.entrypoints=websecure",
          "traefik.http.routers.authentik.tls=true",
          "traefik.http.services.authentik.loadbalancer.server.port={{ authentik_internal_port | default(9000) }}"
        ]
      }

      resources {
        cpu    = 500
        memory = {{ authentik_server_memory | default(2048) }}
      }

      restart {
        interval = "30s"
        delay    = "15s"
        mode     = "delay"
      }
    }

    task "worker" {
      driver = "docker"

      volume_mount {
        volume      = "authentik-media"
        destination = "/media"
      }

      volume_mount {
        volume      = "authentik-certs"
        destination = "/certs"
      }

      volume_mount {
        volume      = "authentik-templates"
        destination = "/templates"
      }

      config {
        image        = "ghcr.io/goauthentik/server:2024.2.2"
        args         = ["worker"]
      }

      template {
        data = <<EOH
CONSUL_HTTP_TOKEN="{{ consul_bootstrap_token | default('') }}"
AUTHENTIK_SECRET_KEY="{{ '{{' }} key "authentik/secret-key" {{ '}}' }}"
AUTHENTIK_REDIS__HOST="{{ '{{' }} env "attr.unique.network.ip-address" {{ '}}' }}"
AUTHENTIK_REDIS__PORT="{{ authentik_redis_port | default(16379) }}"
AUTHENTIK_POSTGRESQL__HOST="{{ '{{' }} env "attr.unique.network.ip-address" {{ '}}' }}"
AUTHENTIK_POSTGRESQL__PORT="{{ authentik_postgres_port | default(15432) }}"
AUTHENTIK_POSTGRESQL__PASSWORD="{{ '{{' }} key "authentik/db-password" {{ '}}' }}"
EOH
        destination = "secrets/authentik.env"
        env         = true
      }

      env {
        AUTHENTIK_POSTGRESQL__USER = "{{ authentik_db_user | default('authentik') }}"
        AUTHENTIK_POSTGRESQL__NAME = "{{ authentik_db_name | default('authentik') }}"
        AUTHENTIK_ERROR_REPORTING__ENABLED = "true"
      }

      resources {
        cpu    = 500
        memory = {{ authentik_worker_memory | default(1024) }}
      }

      restart {
        interval = "30s"
        delay    = "15s"
        mode     = "delay"
      }
    }
  }
}
