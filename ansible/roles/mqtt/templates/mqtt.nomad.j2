job "mqtt" {
  datacenters = {{ nomad_datacenters | default(['dc1']) | to_json }}
  type        = "service"

  group "mqtt-group" {
    count = 1

    network {
      mode = "host"
      port "mqtt" {
        static = {{ mqtt_port }}
      }
      port "mqtts" {
        static = {{ mqtts_port | default(8883) }}
      }
      port "ws" {
        static = {{ mqtt_websocket_port }}
      }
    }

    volume "mqtt-data" {
      type      = "host"
      source    = "mqtt-data"
      read_only = false
    }

    # Service Block at Group Level (Correct Placement)
    service {
      name     = "mqtt"
      port     = "mqtt"
      provider = "consul"
      check {
        # Changed from script to tcp as group level script checks run on host without nc
        type     = "tcp"
        name     = "mqtt_health"
        check_restart {
          limit = 3
          grace = "90s"
          ignore_warnings = false
        }
        interval = "10s"
        timeout  = "5s"
      }
    }
    
    service {
      name     = "mqtts"
      port     = "mqtts"
      provider = "consul"
      check {
        type     = "tcp"
        name     = "mqtts_health"
        check_restart {
          limit = 3
          grace = "90s"
          ignore_warnings = false
        }
        interval = "10s"
        timeout  = "5s"
      }
    }

    restart {
      attempts = 10
      interval = "5m"
      delay    = "25s"
      mode     = "delay"
    }

    {% set image_cid = mosquitto_ipfs_cid %}
    {% set image_tar_name = 'mosquitto' %}
    {% include 'load_image_task.nomad.j2' %}

    task "mosquitto" {
      driver = "docker"

      config {
        image = "eclipse-mosquitto:2"
        network_mode = "host"
        volumes = ["/etc/nomad.d/tls:/mosquitto/certs:ro"]
        # Host mode networking requires no port map here
        cap_add = ["SETUID", "SETGID", "CHOWN", "NET_BIND_SERVICE"]
        command = "mosquitto"
        args    = ["-c", "/mosquitto/config/mosquitto.conf"]
      }

      volume_mount {
        volume      = "mqtt-data"
        destination = "/mosquitto"
        read_only   = false
      }

      resources {
        cpu    = 500
        memory = 256
      }

      user = "1883"
    }
  }
}
