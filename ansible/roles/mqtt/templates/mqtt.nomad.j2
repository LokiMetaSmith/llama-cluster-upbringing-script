job "mqtt" {
  datacenters = ["dc1"]
  type        = "service"

  group "mqtt-group" {
    count = 1

    network {
      port "mqtt" {
        static = 1883
      }
      port "ws" {
        to = 9001
      }
    }

    volume "mqtt-data" {
      type      = "host"
      source    = "mqtt-data"
      read_only = false
    }

    service {
      name     = "mqtt"
      port     = "mqtt"
      provider = "consul"

      check {
        type     = "tcp"
        interval = "10s"
        timeout  = "2s"
      }
    }


    task "mosquitto" {
      driver = "exec"

      config {
        command = "/usr/bin/mosquitto"
        args = ["-c", "/opt/nomad/volumes/mqtt-data/mosquitto.conf"]
      }

      resources {
        cpu    = 200 # 200 MHz
        memory = 128 # 128 MB
      }
    }
  }
}
