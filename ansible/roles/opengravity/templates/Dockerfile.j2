FROM nginx:alpine

# Copy the static website files specifically to avoid copying Dockerfile and conf
COPY index.html /usr/share/nginx/html/
COPY style.css /usr/share/nginx/html/
COPY script.js /usr/share/nginx/html/
COPY agent.js /usr/share/nginx/html/
COPY iconstyles.css /usr/share/nginx/html/
COPY seti.woff /usr/share/nginx/html/
COPY webcontainer/ /usr/share/nginx/html/webcontainer/
COPY assets/ /usr/share/nginx/html/assets/

# Copy the Nginx configuration
COPY default.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
