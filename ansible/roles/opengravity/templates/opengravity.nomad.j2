job "opengravity" {
  datacenters = ["dc1"]
  type        = "service"

  group "web" {
    count = 1

    network {
      port "http" {
        to = 80
      }
    }

    service {
      name = "opengravity"
      port = "http"

      tags = [
        "traefik.enable=true",
        "traefik.http.routers.opengravity.rule=PathPrefix(`/opengravity`)",
        "traefik.http.middlewares.opengravity-stripprefix.stripprefix.prefixes=/opengravity",
        "traefik.http.routers.opengravity.middlewares=opengravity-stripprefix"
      ]

      check {
        type     = "http"
        path     = "/"
        interval = "10s"
        timeout  = "2s"
      }
    }

    {% set image_cid = opengravity_ipfs_cid %}

    {% set image_tar_name = 'opengravity' %}

    {% include 'load_image_task.nomad.j2' %}

    task "nginx" {
      driver = "docker"

      config {
        image = "opengravity:local"
        ports = ["http"]
      }

      resources {
        cpu    = 100
        memory = 64
      }
    }
  }
}
