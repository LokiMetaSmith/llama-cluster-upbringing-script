job "memory-graph" {
  datacenters = {{ nomad_datacenters | default(['dc1']) | to_json }}
  type = "service"

  group "memory" {
    network {
      port "http" { to = 8000 }
    }

    task "load-image" {
      lifecycle {
        hook    = "prestart"
        sidecar = false
      }

      artifact {
        source      = "http://${attr.unique.network.ip-address}:8080/ipfs/{{ memory_graph_ipfs_cid }}"
        destination = "local/memory_graph.tar"
        mode        = "file"
      }

      config {
        command = "docker"
        args    = ["load", "-i", "local/memory_graph.tar"]
      }
    }

    task "server" {
      driver = "docker"
      config {
        image = "{{ memory_graph_image }}"
        force_pull = false
        ports = ["http"]
        # Mount volume for SQLite persistence
        volumes = ["/opt/pipecat/data/memory:/data"]
      }

      env {
        MEMORY_DB_PATH = "/data/memory.db"
      }

      service {
        name = "memory-graph"
        port = "http"
        tags = ["mcp", "memory"]
        check {
          type     = "http"
          path     = "/sse"
          interval = "10s"
          timeout  = "2s"
        }
      }
    }
  }
}
