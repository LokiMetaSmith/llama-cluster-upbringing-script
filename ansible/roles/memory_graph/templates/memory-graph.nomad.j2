job "memory-graph" {
  datacenters = {{ nomad_datacenters | default(['dc1']) | to_json }}
  type = "service"

  group "memory" {
    network {
      port "http" { to = 8000 }
    }

    volume "memory-data" {
      type      = "host"
      source    = "memory-data"
      read_only = false
    }

    {% set image_cid = memory_graph_ipfs_cid %}

    {% set image_tar_name = 'memory_graph' %}

    {% include 'load_image_task.nomad.j2' %}

    task "server" {
      driver = "docker"
      config {
        image = "{{ memory_graph_image }}"
        force_pull = false
        ports = ["http"]
      }

      volume_mount {
        volume      = "memory-data"
        destination = "/data"
        read_only   = false
      }

      env {
        MEMORY_DB_PATH = "/data/memory.db"
      }

      service {
        name = "memory-graph"
        port = "http"
        tags = ["mcp", "memory"]
        check {
          type     = "http"
          path     = "/sse"
          interval = "10s"
          timeout  = "2s"
        }
      }
    }
  }
}
